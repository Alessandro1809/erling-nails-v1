---
import { Image } from "astro:assets";
import icon from "../assets/icon-menu.svg";
import worldIcon from "@/components/icons/WorldLogo.svg";

---


    
<div class="grid grid-cols-3 grid-rows-6 gap-4">

    <div class="row-span-4 border-4 rounded-md p-4 border-theme-gray">
        <h2 class="text-6xl font-bold mb-14 text-theme-gray font-special tracking-wider">Explora la galería de diseños</h2>
        <p class="text-xl mb-5">Relájate con una auténtica experta que te brindá una atención personalizada</p>
        <a class="transition-background inline-flex h-12 items-center justify-center rounded-md border border-theme-red bg-gradient-to-r from-theme-white via-red-300 to-theme-red bg-[length:200%_200%] bg-[0%_0%] px-6 font-medium text-primary hover:text-theme-white duration-500 hover:bg-[99%_200%] focus:outline-none focus:ring-2 focus:ring-theme-red focus:ring-offset-2 focus:ring-offset-theme-red font-special text-4xl" href="/gallery">Explorar</a>
    </div> 

    <div class="row-span-6 col-start-3 row-start-1 border-4 rounded-md p-4">
        <h3 class=" text-5xl font-special text-theme-gray text-center mb-4">Costa Rica</h3>
        <h3 class=" text-7xl font-special text-theme-gray text-center mb-4">Guanacaste</h3>
        <h3 class=" text-5xl font-special text-theme-gray text-center mb-4">Playas del Coco</h3>
        <div class="flex flex-col justify-center mt-10">
            <Image src={worldIcon} alt="Erling Nails" class="w-auto h-32 hover:scale-105 transition-all duration-300 hover:cursor-pointer mb-10" />

            <a class="transition-background inline-flex h-12 items-center justify-center rounded-md border border-theme-red bg-gradient-to-r from-theme-white via-red-300 to-theme-red bg-[length:200%_200%] bg-[0%_0%] px-6 font-medium text-primary hover:text-theme-white duration-500 hover:bg-[99%_200%] focus:outline-none focus:ring-2 focus:ring-theme-red focus:ring-offset-2 focus:ring-offset-theme-red font-special text-4xl" href="/ubication">Ver en maps</a>
            
            <a class="transition-background inline-flex h-12 items-center justify-center rounded-md border border-theme-red bg-gradient-to-l from-theme-red via-red-300 to-theme-red bg-[length:200%_200%] bg-[0%_0%] px-6 font-medium text-primary hover:text-theme-white duration-500 hover:bg-[99%_200%] focus:outline-none focus:ring-2 focus:ring-theme-red focus:ring-offset-2 focus:ring-offset-theme-red font-special text-4xl mt-4" href="/ubication">Contacto</a>

        </div>


    </div>

    <div class="row-span-2 col-start-2 row-start-1 rounded-md p-2 bg-primary text-theme-white">
        <h2 class="text-6xl font-bold mb-2 font-special  tracking-wider text-center">Agenda tu cita ahora mismo!</h2>
        <div class="flex justify-center ">
            <a class="transition-background inline-flex h-12 items-center justify-center rounded-md border border-theme-red bg-gradient-to-r from-theme-white via-red-300 to-theme-red bg-[length:200%_200%] bg-[0%_0%] px-6 font-medium text-primary hover:text-theme-white duration-500 hover:bg-[99%_200%] focus:outline-none focus:ring-2 focus:ring-theme-red focus:ring-offset-2 focus:ring-offset-theme-red font-special text-4xl" href="/contact">Agendar</a>
        </div>
    </div>

    <div class="row-span-2 col-start-2 row-start-3 border-4 rounded-md border-theme-red hover:scale-105 transition-all duration-300 ">
        <div  class="flex flex-col items-center justify-center h-full">
            <h2 class="text-5xl font-bold mb-4 text-theme-red font-special  tracking-wider">Erling Nails</h2>
            <Image src={icon} alt="Erling Nails" class="w-12 h-12 " />
            <h1 class="text-center mt-2 text-xl font-medium font-special">Un espacio dedicado al cuidado de tus manos y pies.</h1>
        </div>
    </div>

    <div class="col-span-2 row-span-2 row-start-5  rounded-md bg-primary text-theme-white p-8">
        <h2 class="text-5xl font-bold font-special  tracking-wide">¿Quieres conocerme un poco más?</h2>
        <div  class="flex items-center justify-center h-full">
        <p class="text-xl mb-5">Averigua más sobre mi trayectoria en el mundo de la manicura y pedicura!</p>
        <a class="transition-background inline-flex h-12 items-center justify-center rounded-md border border-theme-red bg-gradient-to-r from-theme-white via-red-300 to-theme-red bg-[length:200%_200%] bg-[0%_0%] px-6 font-medium text-primary hover:text-theme-white duration-500 hover:bg-[99%_200%] focus:outline-none focus:ring-2 focus:ring-theme-red focus:ring-offset-2 focus:ring-offset-theme-red font-special text-4xl w-[40%] mx-2" href="/about">Sobre mí</a>
        </div>

        
    </div>
 
</div>

    
